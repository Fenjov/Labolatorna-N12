<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Lab12Avalonia.MainWindow"
        Title="Лабораторна робота №12 - Варіант 3 (Атом)" Width="800" Height="600">
    
    <Grid RowDefinitions="*, Auto">
        <Canvas Name="MyCanvas" Background="White" Grid.Row="0" ClipToBounds="True"/>
        
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="10">
            <Button Content="Зберегти зображення (PNG)" Width="250" Height="40" 
                    Click="BtnSave_Click" FontSize="14" FontWeight="Bold"
                    Background="#2196F3" Foreground="White" 
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>